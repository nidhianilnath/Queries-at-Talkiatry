---<1: Providers>----
WITH current_employees AS (
  SELECT
      employee_npi
    , MAX(employee_preferred_name)  AS provider_name
    , MAX(employee_email)           AS provider_email
    , MAX(employee_supervisor_name) AS supervisor_name
  FROM analytics.common.dim_employees
  WHERE employee_separation_date IS NULL
    AND employee_status = 'Active'
  GROUP BY 1
)

, base_visits AS (
  /* Last 365d, visit started >72h ago, billable, and specific statuses */
  SELECT DISTINCT
      fv.visit_id
    , fv.visit_provider_npi
    , fv.patient_id                                AS mrn
    , CAST(fv.visit_date AS DATE)                  AS visit_date
    , fv.visit_start_datetime
    , fv.visit_status
    , COALESCE(fv.is_visit_note_locked, 0)         AS is_visit_note_locked
  FROM analytics.common.fct_visits fv
  WHERE
        CAST(fv.visit_date AS DATE) >= DATEADD('day', -365, CURRENT_DATE)
    AND fv.visit_start_datetime <= DATEADD('hour', -72, CURRENT_TIMESTAMP)
    AND COALESCE(fv.is_visit_billable, 0) = 1
    AND UPPER(COALESCE(fv.visit_status, '')) IN 
        ('CHK', 'ARR', 'LATE CANC', 'NO SHOW', 'PEN')
)

, dedup AS (
  SELECT *
  FROM (
    SELECT
        visit_id
      , visit_provider_npi
      , mrn
      , visit_date
      , visit_start_datetime
      , visit_status
      , is_visit_note_locked
      , ROW_NUMBER() OVER (
            PARTITION BY visit_id 
            ORDER BY visit_start_datetime DESC
        ) AS rn
    FROM base_visits
  )
  WHERE rn = 1
)

, coding_flags AS (
  SELECT
      cca.encounter_id AS visit_id
    , MAX(cca.documentation_error) AS documentation_error
    , MAX(
        CASE
          WHEN NULLIF(TRIM(cca.documentation_error), '') IS NOT NULL THEN 1
          ELSE 0
        END
      ) AS has_doc_error
    , MAX(CASE WHEN cca.last_locked_at IS NOT NULL THEN 1 ELSE 0 END) AS was_ever_locked
    , MAX(cca.last_locked_at) AS last_locked_at
  FROM analytics.products.candid_coding_analytics cca
  GROUP BY 1
)

/* ---------- Last 3 full months: monthly % notes closed within 72h ---------- */
, note_timeliness_monthly AS (
  SELECT
      ce.employee_npi
    , DATE_TRUNC('month', d.visit_date) AS visit_month
    , COUNT(*) AS total_notes_month
    , COUNT_IF(
          cf.last_locked_at IS NOT NULL
      AND cf.last_locked_at <= DATEADD('hour', 72, d.visit_start_datetime)
      ) AS notes_closed_in_72h_month
    , 100.0 * COUNT_IF(
          cf.last_locked_at IS NOT NULL
      AND cf.last_locked_at <= DATEADD('hour', 72, d.visit_start_datetime)
      ) / NULLIF(COUNT(*), 0) AS pct_notes_closed_in_72h_month
  FROM dedup d
  JOIN current_employees ce
    ON d.visit_provider_npi = ce.employee_npi
  LEFT JOIN coding_flags cf
    ON d.visit_id = cf.visit_id
  WHERE d.visit_date >= DATE_TRUNC('month', DATEADD('month', -3, CURRENT_DATE))
    AND d.visit_date < DATE_TRUNC('month', CURRENT_DATE)
    AND UPPER(COALESCE(ce.supervisor_name, '')) NOT IN (
          'ALLISON HOLT'
        , 'ROBERT KRAYN'
        , 'GEORGIA GAVERAS'
        , 'DAVID GUGGENHEIM'
    )
  GROUP BY
      ce.employee_npi
    , DATE_TRUNC('month', d.visit_date)
)

, note_timeliness_3m_avg AS (
  SELECT
      employee_npi
    , AVG(pct_notes_closed_in_72h_month) AS avg_pct_notes_closed_in_72h_last_3m
  FROM note_timeliness_monthly
  GROUP BY 1
)

SELECT
    ce.provider_name
  , ce.provider_email

  /* ---------- NEW COLUMN ---------- */
  , ROUND(nt.avg_pct_notes_closed_in_72h_last_3m, 1) AS avg_pct_notes_closed_in_72h_last_3m

  /* ---------- COUNTS ---------- */
  , COUNT_IF(
      d.is_visit_note_locked = 0
      AND COALESCE(cf.was_ever_locked, 0) = 0
      AND COALESCE(cf.has_doc_error, 0) = 0
    ) AS unlocked_notes_complete_cnt

  , COUNT_IF(
      d.is_visit_note_locked = 0
      AND COALESCE(cf.was_ever_locked, 0) = 0
      AND COALESCE(cf.has_doc_error, 0) = 1
    ) AS unlocked_notes_incomplete_cnt

  , COUNT_IF(
      d.is_visit_note_locked = 0
      AND COALESCE(cf.was_ever_locked, 0) = 1
      AND COALESCE(cf.has_doc_error, 0) = 1
    ) AS autocoded_unlocked_notes_cnt

  , COUNT_IF(
      d.is_visit_note_locked = 1
      AND COALESCE(cf.has_doc_error, 0) = 1
      AND d.visit_date >= DATEADD('day', -45, CURRENT_DATE)
    ) AS autocoded_locked_notes_cnt

  , (
        COUNT_IF(
          d.is_visit_note_locked = 0
          AND COALESCE(cf.was_ever_locked, 0) = 0
          AND COALESCE(cf.has_doc_error, 0) = 0
        )
      + COUNT_IF(
          d.is_visit_note_locked = 0
          AND COALESCE(cf.was_ever_locked, 0) = 0
          AND COALESCE(cf.has_doc_error, 0) = 1
        )
      + COUNT_IF(
          d.is_visit_note_locked = 0
          AND COALESCE(cf.was_ever_locked, 0) = 1
          AND COALESCE(cf.has_doc_error, 0) = 1
        )
      + COUNT_IF(
          d.is_visit_note_locked = 1
          AND COALESCE(cf.has_doc_error, 0) = 1
          AND d.visit_date >= DATEADD('day', -45, CURRENT_DATE)
        )
    ) AS total_notes_cnt

  /* ---------- DETAIL OUTPUT ---------- */
  , LISTAGG(
      CASE
        WHEN d.is_visit_note_locked = 0
         AND COALESCE(cf.was_ever_locked, 0) = 0
         AND COALESCE(cf.has_doc_error, 0) = 0
        THEN d.mrn || ' - ' || TO_CHAR(d.visit_date, 'YYYY-MM-DD')
             || ' - Status: ' || COALESCE(d.visit_status, 'Unknown')
             || ' - Visit ID: ' || d.visit_id
      END
      , '\n'
    ) WITHIN GROUP (ORDER BY d.visit_start_datetime, d.visit_id) 
    AS unlocked_notes_complete

  , LISTAGG(
      CASE
        WHEN d.is_visit_note_locked = 0
         AND COALESCE(cf.was_ever_locked, 0) = 0
         AND COALESCE(cf.has_doc_error, 0) = 1
        THEN d.mrn || ' - ' || TO_CHAR(d.visit_date, 'YYYY-MM-DD')
             || ' - Status: ' || COALESCE(d.visit_status, 'Unknown')
             || ' - Visit ID: ' || d.visit_id
             || ' - Missing: ' 
             || COALESCE(NULLIF(TRIM(cf.documentation_error), ''), 'Missing documentation')
      END
      , '\n'
    ) WITHIN GROUP (ORDER BY d.visit_start_datetime, d.visit_id) 
    AS unlocked_notes_incomplete

  , LISTAGG(
      CASE
        WHEN d.is_visit_note_locked = 0
         AND COALESCE(cf.was_ever_locked, 0) = 1
         AND COALESCE(cf.has_doc_error, 0) = 1
        THEN d.mrn || ' - ' || TO_CHAR(d.visit_date, 'YYYY-MM-DD')
             || ' - Status: ' || COALESCE(d.visit_status, 'Unknown')
             || ' - Visit ID: ' || d.visit_id
             || ' - Missing: ' 
             || COALESCE(NULLIF(TRIM(cf.documentation_error), ''), 'Missing documentation')
      END
      , '\n'
    ) WITHIN GROUP (ORDER BY d.visit_start_datetime, d.visit_id) 
    AS autocoded_unlocked_notes

  , LISTAGG(
      CASE
        WHEN d.is_visit_note_locked = 1
         AND COALESCE(cf.has_doc_error, 0) = 1
         AND d.visit_date >= DATEADD('day', -45, CURRENT_DATE)
        THEN d.mrn || ' - ' || TO_CHAR(d.visit_date, 'YYYY-MM-DD')
             || ' - Status: ' || COALESCE(d.visit_status, 'Unknown')
             || ' - Visit ID: ' || d.visit_id
             || ' - Missing: ' 
             || COALESCE(NULLIF(TRIM(cf.documentation_error), ''), 'Missing documentation')
      END
      , '\n'
    ) WITHIN GROUP (ORDER BY d.visit_start_datetime, d.visit_id) 
    AS autocoded_locked_notes

FROM dedup d
JOIN current_employees ce
  ON d.visit_provider_npi = ce.employee_npi
LEFT JOIN coding_flags cf
  ON d.visit_id = cf.visit_id
LEFT JOIN note_timeliness_3m_avg nt
  ON ce.employee_npi = nt.employee_npi
WHERE UPPER(ce.supervisor_name) NOT IN (
          'ALLISON HOLT'
        , 'ROBERT KRAYN'
        , 'GEORGIA GAVERAS'
        , 'DAVID GUGGENHEIM'
      )
GROUP BY
    ce.provider_name
  , ce.provider_email
  , nt.avg_pct_notes_closed_in_72h_last_3m
HAVING total_notes_cnt > 0
ORDER BY total_notes_cnt DESC NULLS LAST;



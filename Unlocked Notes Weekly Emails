/* ---------- 3-month avg % closed within 72h ---------- */
, note_timeliness_monthly AS (
  SELECT
      ce.employee_npi
    , DATE_TRUNC('month', d.visit_date) AS visit_month
    , COUNT(*) AS total_notes_month
    , COUNT_IF(
          cf.last_locked_at IS NOT NULL
      AND cf.last_locked_at <= DATEADD('hour', 72, d.visit_start_datetime)
      ) AS notes_closed_in_72h_month
    , 100.0 * COUNT_IF(
          cf.last_locked_at IS NOT NULL
      AND cf.last_locked_at <= DATEADD('hour', 72, d.visit_start_datetime)
      ) / NULLIF(COUNT(*), 0) AS pct_notes_closed_in_72h_month
  FROM dedup d
  JOIN current_employees ce
    ON d.visit_provider_npi = ce.employee_npi
  LEFT JOIN coding_flags cf
    ON d.visit_id = cf.visit_id
  WHERE d.visit_date >= DATE_TRUNC('month', DATEADD('month', -3, CURRENT_DATE))
    AND d.visit_date < DATE_TRUNC('month', CURRENT_DATE)
  GROUP BY
      ce.employee_npi
    , DATE_TRUNC('month', d.visit_date)
)

, note_timeliness_3m_avg AS (
  SELECT
      employee_npi
    , AVG(pct_notes_closed_in_72h_month) AS avg_pct_closed_in_72h_last_3m
  FROM note_timeliness_monthly
  GROUP BY 1
)

, visits_labeled AS (
  SELECT
      d.visit_id
    , d.mrn
    , d.visit_date
    , d.visit_start_datetime
    , d.visit_status
    , d.is_visit_note_locked

    , ce.employee_npi
    , ce.provider_name
    , ce.provider_email
    , ce.chief_name
    , ce.chief_email

    , COALESCE(cf.has_doc_error, 0)   AS has_doc_error
    , COALESCE(cf.was_ever_locked, 0) AS was_ever_locked
    , COALESCE(NULLIF(TRIM(cf.documentation_error), ''), 'Missing documentation') AS documentation_error

    /* 1) Unlocked Notes – Complete */
    , CASE
        WHEN d.is_visit_note_locked = 0
         AND COALESCE(cf.was_ever_locked, 0) = 0
         AND COALESCE(cf.has_doc_error, 0) = 0
        THEN d.mrn || ' - ' || TO_CHAR(d.visit_date, 'YYYY-MM-DD')
             || ' - Status: ' || COALESCE(d.visit_status, 'Unknown')
             || ' - Visit ID: ' || d.visit_id
      END AS unlocked_notes_complete_entry

    /* 2) Unlocked Notes – Incomplete */
    , CASE
        WHEN d.is_visit_note_locked = 0
         AND COALESCE(cf.was_ever_locked, 0) = 0
         AND COALESCE(cf.has_doc_error, 0) = 1
        THEN d.mrn || ' - ' || TO_CHAR(d.visit_date, 'YYYY-MM-DD')
             || ' - Status: ' || COALESCE(d.visit_status, 'Unknown')
             || ' - Visit ID: ' || d.visit_id
             || ' - Missing: ' || documentation_error
      END AS unlocked_notes_incomplete_entry

    /* 3) Autocoded Unlocked Notes */
    , CASE
        WHEN d.is_visit_note_locked = 0
         AND COALESCE(cf.was_ever_locked, 0) = 1
         AND COALESCE(cf.has_doc_error, 0) = 1
        THEN d.mrn || ' - ' || TO_CHAR(d.visit_date, 'YYYY-MM-DD')
             || ' - Status: ' || COALESCE(d.visit_status, 'Unknown')
             || ' - Visit ID: ' || d.visit_id
             || ' - Missing: ' || documentation_error
      END AS autocoded_unlocked_notes_entry

    /* 4) Autocoded Locked Notes */
    , CASE
        WHEN d.is_visit_note_locked = 1
         AND COALESCE(cf.has_doc_error, 0) = 1
         AND d.visit_date >= DATEADD('day', -45, CURRENT_DATE)
        THEN d.mrn || ' - ' || TO_CHAR(d.visit_date, 'YYYY-MM-DD')
             || ' - Status: ' || COALESCE(d.visit_status, 'Unknown')
             || ' - Visit ID: ' || d.visit_id
             || ' - Missing: ' || documentation_error
      END AS autocoded_locked_notes_entry

  FROM dedup d
  JOIN current_employees ce
    ON d.visit_provider_npi = ce.employee_npi
  LEFT JOIN coding_flags cf
    ON d.visit_id = cf.visit_id
)

, provider_rollup AS (
  SELECT
      vl.chief_name
    , vl.chief_email
    , vl.provider_name
    , vl.provider_email
    , ROUND(nt.avg_pct_closed_in_72h_last_3m, 1) AS avg_pct_closed_in_72h_last_3m

    , COUNT_IF(vl.unlocked_notes_complete_entry IS NOT NULL)   AS unlocked_notes_complete_cnt
    , COUNT_IF(vl.unlocked_notes_incomplete_entry IS NOT NULL) AS unlocked_notes_incomplete_cnt
    , COUNT_IF(vl.autocoded_unlocked_notes_entry IS NOT NULL)  AS autocoded_unlocked_notes_cnt
    , COUNT_IF(vl.autocoded_locked_notes_entry IS NOT NULL)    AS autocoded_locked_notes_cnt

    , (
        COUNT_IF(vl.unlocked_notes_complete_entry IS NOT NULL)
      + COUNT_IF(vl.unlocked_notes_incomplete_entry IS NOT NULL)
      + COUNT_IF(vl.autocoded_unlocked_notes_entry IS NOT NULL)
      + COUNT_IF(vl.autocoded_locked_notes_entry IS NOT NULL)
      ) AS provider_total_notes_cnt

    , LISTAGG(vl.unlocked_notes_complete_entry, '\n')
        WITHIN GROUP (ORDER BY vl.visit_start_datetime, vl.visit_id) AS unlocked_notes_complete

    , LISTAGG(vl.unlocked_notes_incomplete_entry, '\n')
        WITHIN GROUP (ORDER BY vl.visit_start_datetime, vl.visit_id) AS unlocked_notes_incomplete

    , LISTAGG(vl.autocoded_unlocked_notes_entry, '\n')
        WITHIN GROUP (ORDER BY vl.visit_start_datetime, vl.visit_id) AS autocoded_unlocked_notes

    , LISTAGG(vl.autocoded_locked_notes_entry, '\n')
        WITHIN GROUP (ORDER BY vl.visit_start_datetime, vl.visit_id) AS autocoded_locked_notes

  FROM visits_labeled vl
  LEFT JOIN note_timeliness_3m_avg nt
    ON vl.employee_npi = nt.employee_npi
  GROUP BY
      vl.chief_name
    , vl.chief_email
    , vl.provider_name
    , vl.provider_email
    , nt.avg_pct_closed_in_72h_last_3m
  HAVING provider_total_notes_cnt > 0
)

, chief_rollup AS (
  SELECT
      chief_name
    , chief_email
    , SUM(provider_total_notes_cnt) AS chief_total_notes_cnt

    , LISTAGG(
          provider_name || ' - Total: ' || provider_total_notes_cnt
          || CHR(10) || '  • Unlocked Complete: '   || unlocked_notes_complete_cnt
          || CHR(10) || '  • Unlocked Incomplete: ' || unlocked_notes_incomplete_cnt
          || CHR(10) || '  • Autocoded Unlocked: '  || autocoded_unlocked_notes_cnt
          || CHR(10) || '  • Autocoded Locked: '    || autocoded_locked_notes_cnt
          || CHR(10) || '  • % closed within 72 hours: '
          || COALESCE(TO_VARCHAR(avg_pct_closed_in_72h_last_3m), 'N/A') || '%'
        , '\n\n'
      ) WITHIN GROUP (ORDER BY provider_total_notes_cnt DESC, provider_name)
      AS providers_and_counts

  FROM provider_rollup
  GROUP BY
      chief_name
    , chief_email
)

SELECT
    cr.chief_name
  , cr.chief_email
  , cr.chief_total_notes_cnt
  , cr.providers_and_counts
FROM chief_rollup cr
WHERE UPPER(cr.chief_name) NOT IN (
          'ALLISON HOLT'
        , 'ROBERT KRAYN'
        , 'GEORGIA GAVERAS'
        , 'DAVID GUGGENHEIM'
      )
  AND cr.chief_total_notes_cnt > 0
ORDER BY
    cr.chief_total_notes_cnt DESC
  , cr.chief_name;


WITH params AS (
  SELECT DATE '2026-01-01' AS start_date, DATE '2026-2-28' AS end_date
),

visits_scope AS (
  SELECT
    fv.visit_id,
    fv.visit_provider_npi,
    fv.visit_date::TIMESTAMP_NTZ AS appt_start_ts,
    TRY_TO_TIMESTAMP_NTZ(TO_VARCHAR(fv.visit_note_first_locked_at)) AS visit_first_locked_ts,
    TRY_TO_TIMESTAMP_NTZ(TO_VARCHAR(fv.visit_note_last_locked_at))  AS visit_last_locked_ts
  FROM analytics.common.fct_visits fv
  WHERE fv.visit_date::DATE BETWEEN (SELECT start_date FROM params)
                                 AND (SELECT end_date FROM params)
    AND COALESCE(fv.is_visit_billable, 0) = 1
    AND UPPER(COALESCE(fv.visit_status, '')) IN ('CHK','ARR','LATE CANC','NO SHOW')
),

candid_lock AS (
  SELECT
    cca.encounter_id AS visit_id,
    MAX(TRY_TO_TIMESTAMP_NTZ(TO_VARCHAR(cca.last_locked_at))) AS candid_last_locked_ts
  FROM analytics.products.candid_coding_analytics cca
  GROUP BY 1
),

provider_class AS (
  SELECT
    p.employee_npi AS provider_npi,
    CASE
      WHEN p.provider_type IN ('Doctor','Nurse Practitioner') THEN 'Psych'
      ELSE 'Therapy'
    END AS provider_category
  FROM analytics.common.dim_employees p
),

locks_resolved AS (
  SELECT
    v.*,
    v.visit_first_locked_ts AS first_lock_ts_used,
    COALESCE(v.visit_last_locked_ts, cl.candid_last_locked_ts) AS last_lock_ts_used,
    COALESCE(v.visit_first_locked_ts, v.visit_last_locked_ts, cl.candid_last_locked_ts) AS any_lock_ts_used
  FROM visits_scope v
  LEFT JOIN candid_lock cl
    ON cl.visit_id = v.visit_id
),

denom AS (
  SELECT
    lr.*,
    COALESCE(pc.provider_category, 'Therapy') AS provider_category
  FROM locks_resolved lr
  LEFT JOIN provider_class pc
    ON pc.provider_npi = lr.visit_provider_npi
  WHERE any_lock_ts_used IS NOT NULL
),

calc AS (
  SELECT
    provider_category,
    CASE
      WHEN first_lock_ts_used IS NOT NULL THEN
        DATEDIFF(
          'minute',
          appt_start_ts,
          GREATEST(appt_start_ts, first_lock_ts_used)
        )
      ELSE NULL
    END AS mins_to_first_lock
  FROM denom
)

SELECT
  provider_category,
  COUNT(*) AS visits_with_any_lock,                                 -- "all notes" per your current denom
  COUNT(CASE WHEN mins_to_first_lock IS NOT NULL THEN 1 END) AS visits_with_first_lock,
  AVG(mins_to_first_lock) AS avg_mins_to_first_lock,
  MEDIAN(mins_to_first_lock) AS median_mins_to_first_lock
FROM calc
GROUP BY 1
ORDER BY 1;

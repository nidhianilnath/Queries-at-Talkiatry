provider_class AS (
  SELECT
    p.employee_npi AS provider_npi,
    CASE
      WHEN p.provider_type IN ('Doctor','Nurse Practitioner') THEN 'Psych'
      ELSE 'Therapy'
    END AS provider_category
  FROM analytics.common.dim_employees p
),

/* --- Resolve lock timestamps (same as your original pattern) --- */
locks_resolved AS (
  SELECT
    v.*,
    v.visit_first_locked_ts AS first_lock_ts_used,
    COALESCE(v.visit_last_locked_ts, cl.candid_last_locked_ts) AS last_lock_ts_used,
    COALESCE(v.visit_first_locked_ts, v.visit_last_locked_ts, cl.candid_last_locked_ts) AS any_lock_ts_used
  FROM visits_scope v
  LEFT JOIN candid_lock cl
    ON cl.visit_id = v.visit_id
),

/* --- Denominator: visits that have any lock evidence --- */
denom AS (
  SELECT
    lr.*,
    COALESCE(pc.provider_category, 'Therapy') AS provider_category
  FROM locks_resolved lr
  LEFT JOIN provider_class pc
    ON pc.provider_npi = lr.visit_provider_npi
  WHERE any_lock_ts_used IS NOT NULL
),

calc AS (
  SELECT
    visit_id,
    visit_quarter,
    provider_category,

    appt_start_ts,
    first_lock_ts_used,

    /* Minutes to first lock (guard against bad negative timestamps) */
    CASE
      WHEN first_lock_ts_used IS NOT NULL THEN
        DATEDIFF(
          'minute',
          appt_start_ts,
          GREATEST(appt_start_ts, first_lock_ts_used)
        )
      ELSE NULL
    END AS mins_to_first_lock
  FROM denom
)

SELECT
  visit_quarter AS quarter_start,
  CONCAT(YEAR(visit_quarter), '-Q', QUARTER(visit_quarter)) AS quarter,
  provider_category,

  COUNT(DISTINCT visit_id) AS denom_visits_with_any_lock,

  /* counts */
  COUNT(DISTINCT CASE WHEN mins_to_first_lock IS NOT NULL AND mins_to_first_lock <  72*60 THEN visit_id END) AS n_lt_72h,
  COUNT(DISTINCT CASE WHEN mins_to_first_lock IS NOT NULL AND mins_to_first_lock >= 72*60 AND mins_to_first_lock <  96*60 THEN visit_id END) AS n_72_96h,
  COUNT(DISTINCT CASE WHEN mins_to_first_lock IS NOT NULL AND mins_to_first_lock >= 96*60 AND mins_to_first_lock < 120*60 THEN visit_id END) AS n_96_120h,
  COUNT(DISTINCT CASE WHEN mins_to_first_lock IS NOT NULL AND mins_to_first_lock >= 120*60 THEN visit_id END) AS n_120h_plus,

  /* percents (of visits with a computable first lock timestamp) */
  COUNT(DISTINCT CASE WHEN mins_to_first_lock IS NOT NULL THEN visit_id END) AS denom_visits_with_first_lock,

  ROUND(
    COUNT(DISTINCT CASE WHEN mins_to_first_lock IS NOT NULL AND mins_to_first_lock < 72*60 THEN visit_id END)::FLOAT
    / NULLIF(COUNT(DISTINCT CASE WHEN mins_to_first_lock IS NOT NULL THEN visit_id END), 0),
    4
  ) AS pct_lt_72h,

  ROUND(
    COUNT(DISTINCT CASE WHEN mins_to_first_lock IS NOT NULL AND mins_to_first_lock >= 72*60 AND mins_to_first_lock < 96*60 THEN visit_id END)::FLOAT
    / NULLIF(COUNT(DISTINCT CASE WHEN mins_to_first_lock IS NOT NULL THEN visit_id END), 0),
    4
  ) AS pct_72_96h,

  ROUND(
    COUNT(DISTINCT CASE WHEN mins_to_first_lock IS NOT NULL AND mins_to_first_lock >= 96*60 AND mins_to_first_lock < 120*60 THEN visit_id END)::FLOAT
    / NULLIF(COUNT(DISTINCT CASE WHEN mins_to_first_lock IS NOT NULL THEN visit_id END), 0),
    4
  ) AS pct_96_120h,

  ROUND(
    COUNT(DISTINCT CASE WHEN mins_to_first_lock IS NOT NULL AND mins_to_first_lock >= 120*60 THEN visit_id END)::FLOAT
    / NULLIF(COUNT(DISTINCT CASE WHEN mins_to_first_lock IS NOT NULL THEN visit_id END), 0),
    4
  ) AS pct_120h_plus

FROM calc
GROUP BY 1,2,3
ORDER BY 1,3;

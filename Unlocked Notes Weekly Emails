WITH current_employees AS (
  -- Active providers with their chief mapping
  SELECT
      employee_npi,
      MAX(employee_full_name)        AS provider_name,
      MAX(employee_email)            AS provider_email,
      MAX(employee_supervisor_name)  AS chief_name
  FROM analytics.common.dim_employees
  WHERE employee_separation_date IS NULL
    AND employee_status = 'Active'
  GROUP BY 1
),

candidate_visits AS (
  -- Last 365d, unlocked now, open >3d, billable, and specific visit types (CHK, ARR, LATE CANC, NO SHOW)
  SELECT DISTINCT
      fv.visit_id,
      fv.visit_provider_npi,
      fv.patient_id                       AS mrn,
      CAST(fv.visit_date AS DATE)         AS visit_date,
      fv.visit_status
  FROM analytics.common.fct_visits fv
  WHERE
      CAST(fv.visit_date AS DATE) >= DATEADD('day', -365, CURRENT_DATE)
      AND CAST(fv.visit_date AS DATE) <= DATEADD('day', -3, CURRENT_DATE)
      AND COALESCE(fv.is_visit_billable, 0) = 1
      AND COALESCE(fv.is_visit_note_locked, 0) = 0
      AND UPPER(COALESCE(fv.visit_status, '')) IN ('CHK','ARR','LATE CANC','NO SHOW')
),

dedup AS (
  -- Ensure only one row per visit_id
  SELECT *
  FROM (
    SELECT
        visit_id, visit_provider_npi, mrn, visit_date, visit_status,
        ROW_NUMBER() OVER (PARTITION BY visit_id ORDER BY visit_date DESC) AS rn
    FROM candidate_visits
  )
  WHERE rn = 1
),

coding_flags AS (
  -- Documentation flags from Candid Coding
  SELECT
      cca.encounter_id                                         AS visit_id,
      MAX(cca.documentation_error)                             AS documentation_error,
      MAX(
          CASE
            WHEN NULLIF(TRIM(cca.documentation_error), '') IS NOT NULL THEN 1
            ELSE 0
          END
      )                                                        AS has_doc_error,
      MAX(CASE WHEN cca.last_locked_at IS NOT NULL THEN 1 ELSE 0 END) AS was_ever_locked
  FROM analytics.products.candid_coding_analytics cca
  WHERE COALESCE(cca.is_visit_billable_and_locked, 1) = 0
  GROUP BY 1
)

SELECT
    ce.chief_name,
    ce.provider_name,
    ce.provider_email,
    d.visit_id,
    d.mrn,
    d.visit_date,
    d.visit_status,
    COALESCE(cf.was_ever_locked, 0)          AS was_ever_locked,
    COALESCE(cf.has_doc_error, 0)            AS has_doc_error,
    COALESCE(NULLIF(TRIM(cf.documentation_error), ''), NULL) AS documentation_error,

    /* Derived classification for easier downstream analysis */
    CASE
    WHEN COALESCE(cf.has_doc_error, 0) = 0
    THEN 'General Unlocked - Completed'

    WHEN COALESCE(cf.has_doc_error, 0) = 1
     AND COALESCE(cf.was_ever_locked, 0) = 0
    THEN 'General Unlocked - Incomplete'

    WHEN COALESCE(cf.has_doc_error, 0) = 1
     AND COALESCE(cf.was_ever_locked, 0) = 1
    THEN 'Autocoded Unlocked'

    ELSE 'Other'
END AS unlocked_note_type


FROM dedup d
JOIN current_employees ce
  ON d.visit_provider_npi = ce.employee_npi
LEFT JOIN coding_flags cf
  ON d.visit_id = cf.visit_id
WHERE UPPER(ce.chief_name) NOT IN (
    'ALLISON HOLT',
    'ROBERT KRAYN',
    'GEORGIA GAVERAS',
    'DAVID GUGGENHEIM'
)
ORDER BY ce.chief_name, ce.provider_name, d.visit_date DESC;

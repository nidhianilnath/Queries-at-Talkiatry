/* ============================================================
   Unlocked Notes — 4 Metrics in One Query
   - Metric 1 & 2: EXACTLY your provided logic
   - Adds Metric 3 (Avg hours to lock) & Metric 4 (Aging buckets snapshot)
   ============================================================ */

WITH params AS (
  /* keep your quarterly window for metrics 1–3 */
  SELECT
    DATE '2025-01-01' AS start_date,
    DATE '2025-12-31' AS end_date
),

/* --- Visit universe (for quarterly metrics 1–3) --- */
visits_scope AS (
  SELECT
    fv.visit_id,
    fv.patient_id                 AS mrn,
    fv.visit_provider_npi,
    fv.visit_status,

    fv.visit_date::TIMESTAMP_NTZ  AS appt_start_ts,
    DATE_TRUNC('quarter', fv.visit_date)::DATE AS visit_quarter,

    COALESCE(fv.is_visit_billable, 0) AS is_billable,

    TRY_TO_TIMESTAMP_NTZ(TO_VARCHAR(fv.visit_note_first_locked_at)) AS visit_first_locked_ts,
    TRY_TO_TIMESTAMP_NTZ(TO_VARCHAR(fv.visit_note_last_locked_at))  AS visit_last_locked_ts
  FROM analytics.common.fct_visits fv
  WHERE fv.visit_date::DATE BETWEEN (SELECT start_date FROM params)
                                 AND (SELECT end_date FROM params)
    AND COALESCE(fv.is_visit_billable, 0) = 1
    AND UPPER(COALESCE(fv.visit_status, '')) IN ('CHK','ARR','LATE CANC','NO SHOW')
),

/* --- Candid lock fallback (EXACTLY as in your query) --- */
candid_lock AS (
  SELECT
    cca.encounter_id AS visit_id,
    MAX(TRY_TO_TIMESTAMP_NTZ(TO_VARCHAR(cca.last_locked_at))) AS candid_last_locked_ts
  FROM analytics.products.candid_coding_analytics cca
  GROUP BY 1
),

/* --- Provider credentials -> Psych vs Therapy (EXACTLY as in your query) --- */
provider_class AS (
  SELECT
    p.employee_npi AS provider_npi,
    CASE
      WHEN p.provider_type IN ('Doctor','Nurse Practitioner') THEN 'Psych'
      ELSE 'Therapy'
    END AS provider_category
  FROM analytics.common.dim_employees p
),

/* --- Resolve lock timestamps (EXACTLY as in your query) --- */
locks_resolved AS (
  SELECT
    v.*,

    /* First lock only from visit field */
    v.visit_first_locked_ts AS first_lock_ts_used,

    /* Last lock with fallback */
    COALESCE(
      v.visit_last_locked_ts,
      cl.candid_last_locked_ts
    ) AS last_lock_ts_used,

    /* Any lock (proxy for "has a note") */
    COALESCE(
      v.visit_first_locked_ts,
      v.visit_last_locked_ts,
      cl.candid_last_locked_ts
    ) AS any_lock_ts_used
  FROM visits_scope v
  LEFT JOIN candid_lock cl
    ON cl.visit_id = v.visit_id
),

/* --- Denominator for Metric 1: include notes even if first lock missing (EXACT) --- */
denom AS (
  SELECT
    lr.*,
    pc.provider_category
  FROM locks_resolved lr
  LEFT JOIN provider_class pc
    ON pc.provider_npi = lr.visit_provider_npi
  WHERE any_lock_ts_used IS NOT NULL
),

/* --- Calc (EXACT for metrics 1 & 2, plus adds hours_to_lock for metric 3) --- */
calc AS (
  SELECT
    visit_id,
    mrn,
    visit_provider_npi,
    COALESCE(provider_category, 'Therapy') AS provider_category,
    visit_status,
    visit_quarter,
    appt_start_ts,
    first_lock_ts_used,
    last_lock_ts_used,

    /* Metric 1 flag: only computable if first lock exists */
    CASE
      WHEN first_lock_ts_used IS NOT NULL
       AND DATEDIFF(
             'minute',
             appt_start_ts,
             GREATEST(appt_start_ts, first_lock_ts_used)
           ) <= 72 * 60
      THEN 1 ELSE 0
    END AS first_locked_within_72h_flag,

    /* Metric 2: Reopened flag only makes sense if first + last exist */
    CASE
      WHEN first_lock_ts_used IS NOT NULL
       AND last_lock_ts_used  IS NOT NULL
       AND last_lock_ts_used > first_lock_ts_used
      THEN 1 ELSE 0
    END AS reopened_flag,

    /* Metric 3 helper: hours from appt -> last lock (with safety guard) */
    CASE
      WHEN last_lock_ts_used IS NOT NULL THEN
        DATEDIFF(
          'minute',
          appt_start_ts,
          GREATEST(appt_start_ts, last_lock_ts_used)
        ) / 60.0
      ELSE NULL
    END AS hours_to_lock

  FROM denom
),

/* ============================================================
   Metric 4: Aging buckets snapshot (never locked + >72h)
   Note: This is independent of the quarterly window and uses 365d lookback
   ============================================================ */
aging_visits AS (
  SELECT
    fv.visit_id,
    fv.visit_provider_npi,
    fv.visit_date::TIMESTAMP_NTZ AS appt_start_ts,

    TRY_TO_TIMESTAMP_NTZ(TO_VARCHAR(fv.visit_note_first_locked_at)) AS visit_first_locked_ts,
    TRY_TO_TIMESTAMP_NTZ(TO_VARCHAR(fv.visit_note_last_locked_at))  AS visit_last_locked_ts
  FROM analytics.common.fct_visits fv
  WHERE fv.visit_date::DATE BETWEEN DATEADD('day', -365, CURRENT_DATE()) AND CURRENT_DATE()
    AND COALESCE(fv.is_visit_billable, 0) = 1
    AND UPPER(COALESCE(fv.visit_status, '')) IN ('CHK','ARR','LATE CANC','NO SHOW')
),

aging_locks_resolved AS (
  SELECT
    av.*,
    COALESCE(av.visit_first_locked_ts, av.visit_last_locked_ts, cl.candid_last_locked_ts) AS any_lock_ts_used
  FROM aging_visits av
  LEFT JOIN candid_lock cl
    ON cl.visit_id = av.visit_id
),

aging_calc AS (
  SELECT
    alr.visit_id,
    COALESCE(pc.provider_category, 'Therapy') AS provider_category,
    DATEDIFF('hour', alr.appt_start_ts, CURRENT_TIMESTAMP()::TIMESTAMP_NTZ) AS hours_since_appt,
    CASE
      WHEN DATEDIFF('hour', alr.appt_start_ts, CURRENT_TIMESTAMP()::TIMESTAMP_NTZ) > 72
       AND DATEDIFF('hour', alr.appt_start_ts, CURRENT_TIMESTAMP()::TIMESTAMP_NTZ) <= 96
      THEN '72-96h'
      WHEN DATEDIFF('hour', alr.appt_start_ts, CURRENT_TIMESTAMP()::TIMESTAMP_NTZ) > 96
       AND DATEDIFF('hour', alr.appt_start_ts, CURRENT_TIMESTAMP()::TIMESTAMP_NTZ) <= 120
      THEN '96-120h'
      WHEN DATEDIFF('hour', alr.appt_start_ts, CURRENT_TIMESTAMP()::TIMESTAMP_NTZ) > 120
      THEN '120h+'
      ELSE NULL
    END AS aging_bucket
  FROM aging_locks_resolved alr
  LEFT JOIN provider_class pc
    ON pc.provider_npi = alr.visit_provider_npi
  WHERE alr.any_lock_ts_used IS NULL
    AND DATEDIFF('hour', alr.appt_start_ts, CURRENT_TIMESTAMP()::TIMESTAMP_NTZ) > 72
)

/* ============================================================
   FINAL OUTPUT (one table)
   ============================================================ */
SELECT
  'Notes Locked in 72 Hours (%)' AS metric_name,
  'quarter' AS period_type,
  visit_quarter AS period_start,
  CONCAT(YEAR(visit_quarter), '-Q', QUARTER(visit_quarter)) AS period_label,
  provider_category,
  NULL AS aging_bucket,
  COUNT(DISTINCT visit_id) AS denom,
  COUNT(DISTINCT CASE WHEN first_locked_within_72h_flag = 1 THEN visit_id END) AS num,
  ROUND(
    COUNT(DISTINCT CASE WHEN first_locked_within_72h_flag = 1 THEN visit_id END)::FLOAT
    / NULLIF(COUNT(DISTINCT visit_id), 0),
    4
  ) AS value
FROM calc
GROUP BY 1,2,3,4,5,6

UNION ALL

SELECT
  'Notes Reopened After Locked in 72 Hours (%)' AS metric_name,
  'quarter' AS period_type,
  visit_quarter AS period_start,
  CONCAT(YEAR(visit_quarter), '-Q', QUARTER(visit_quarter)) AS period_label,
  provider_category,
  NULL AS aging_bucket,
  COUNT(DISTINCT CASE WHEN first_locked_within_72h_flag = 1 THEN visit_id END) AS denom,
  COUNT(DISTINCT CASE WHEN first_locked_within_72h_flag = 1 AND reopened_flag = 1 THEN visit_id END) AS num,
  ROUND(
    COUNT(DISTINCT CASE WHEN first_locked_within_72h_flag = 1 AND reopened_flag = 1 THEN visit_id END)::FLOAT
    / NULLIF(COUNT(DISTINCT CASE WHEN first_locked_within_72h_flag = 1 THEN visit_id END), 0),
    4
  ) AS value
FROM calc
GROUP BY 1,2,3,4,5,6

UNION ALL

SELECT
  'Average Time to Lock Notes (Hours)' AS metric_name,
  'quarter' AS period_type,
  visit_quarter AS period_start,
  CONCAT(YEAR(visit_quarter), '-Q', QUARTER(visit_quarter)) AS period_label,
  provider_category,
  NULL AS aging_bucket,
  COUNT(DISTINCT visit_id) AS denom,
  COUNT(DISTINCT CASE WHEN hours_to_lock IS NOT NULL THEN visit_id END) AS num,
  ROUND(AVG(hours_to_lock), 2) AS value
FROM calc
WHERE hours_to_lock IS NOT NULL
GROUP BY 1,2,3,4,5,6

UNION ALL

SELECT
  'Locking Notes Aging Buckets (Count)' AS metric_name,
  'snapshot' AS period_type,
  CURRENT_DATE() AS period_start,
  TO_VARCHAR(CURRENT_DATE()) AS period_label,
  provider_category,
  aging_bucket,
  NULL AS denom,
  COUNT(DISTINCT visit_id) AS num,
  COUNT(DISTINCT visit_id)::FLOAT AS value
FROM aging_calc
WHERE aging_bucket IS NOT NULL
GROUP BY 1,2,3,4,5,6

ORDER BY
  period_type,
  period_start,
  provider_category,
  metric_name,
  CASE aging_bucket
    WHEN '72-96h' THEN 1
    WHEN '96-120h' THEN 2
    WHEN '120h+' THEN 3
    ELSE 99
  END;

      END AS unlocked_notes_incomplete_entry

    /* 3) Autocoded Unlocked Notes (detailed) */
    , CASE
        WHEN d.is_visit_note_locked = 0
         AND COALESCE(cf.was_ever_locked, 0) = 1
         AND COALESCE(cf.has_doc_error, 0) = 1
        THEN d.mrn || ' - ' || TO_CHAR(d.visit_date, 'YYYY-MM-DD')
             || ' - Status: ' || COALESCE(d.visit_status, 'Unknown')
             || ' - Visit ID: ' || d.visit_id
             || ' - Missing: ' || COALESCE(NULLIF(TRIM(cf.documentation_error), ''), 'Missing documentation')
      END AS autocoded_unlocked_notes_entry

    /* 4) Autocoded Locked Notes (detailed) */
    , CASE
        WHEN d.is_visit_note_locked = 1
         AND COALESCE(cf.has_doc_error, 0) = 1
         AND d.visit_date >= DATEADD('day', -45, CURRENT_DATE)
        THEN d.mrn || ' - ' || TO_CHAR(d.visit_date, 'YYYY-MM-DD')
             || ' - Status: ' || COALESCE(d.visit_status, 'Unknown')
             || ' - Visit ID: ' || d.visit_id
             || ' - Missing: ' || COALESCE(NULLIF(TRIM(cf.documentation_error), ''), 'Missing documentation')
      END AS autocoded_locked_notes_entry

  FROM dedup d
  JOIN current_employees ce
    ON d.visit_provider_npi = ce.employee_npi
  LEFT JOIN coding_flags cf
    ON d.visit_id = cf.visit_id
)

, provider_rollup AS (
  -- Per-provider counts, totals, and categorized lists
  SELECT
      vl.chief_name
    , vl.chief_email
    , vl.provider_name
    , vl.provider_email
    , ROUND(nt.avg_pct_closed_in_72h_last_3m, 1) AS avg_pct_closed_in_72h_last_3m

    , COUNT_IF(vl.unlocked_notes_complete_entry IS NOT NULL)   AS unlocked_notes_complete_cnt
    , COUNT_IF(vl.unlocked_notes_incomplete_entry IS NOT NULL) AS unlocked_notes_incomplete_cnt
    , COUNT_IF(vl.autocoded_unlocked_notes_entry IS NOT NULL)  AS autocoded_unlocked_notes_cnt
    , COUNT_IF(vl.autocoded_locked_notes_entry IS NOT NULL)    AS autocoded_locked_notes_cnt

    , (
        COUNT_IF(vl.unlocked_notes_complete_entry IS NOT NULL)
      + COUNT_IF(vl.unlocked_notes_incomplete_entry IS NOT NULL)
      + COUNT_IF(vl.autocoded_unlocked_notes_entry IS NOT NULL)
      + COUNT_IF(vl.autocoded_locked_notes_entry IS NOT NULL)
      ) AS provider_total_notes_cnt

    , LISTAGG(vl.unlocked_notes_complete_entry, '\n')   WITHIN GROUP (ORDER BY vl.visit_date, vl.visit_id) AS unlocked_notes_complete
    , LISTAGG(vl.unlocked_notes_incomplete_entry, '\n') WITHIN GROUP (ORDER BY vl.visit_date, vl.visit_id) AS unlocked_notes_incomplete
    , LISTAGG(vl.autocoded_unlocked_notes_entry, '\n')  WITHIN GROUP (ORDER BY vl.visit_date, vl.visit_id) AS autocoded_unlocked_notes
    , LISTAGG(vl.autocoded_locked_notes_entry, '\n')    WITHIN GROUP (ORDER BY vl.visit_date, vl.visit_id) AS autocoded_locked_notes

  FROM visits_labeled vl
  LEFT JOIN note_timeliness_3m_avg nt
    ON vl.employee_npi = nt.employee_npi
  GROUP BY
      vl.chief_name
    , vl.chief_email
    , vl.provider_name
    , vl.provider_email
